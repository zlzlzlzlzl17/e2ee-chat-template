# Copy this file to .env before deploying the Node server.
# These values are examples only. Replace every secret before using in production.

PORT=3000
JWT_SECRET=replace-with-a-long-random-secret
DB_PATH=./data/chat.sqlite
UPLOAD_DIR=./uploads
APP_RELEASE_DIR=./app_release
MANAGE_HOST=manage.example.com
SEED_DEMO_USERS=false

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

CALL_STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
CALL_TURN_URLS=
CALL_TURN_USERNAME=
CALL_TURN_CREDENTIAL=
