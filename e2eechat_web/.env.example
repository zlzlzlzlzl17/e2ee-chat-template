PORT=3000
JWT_SECRET=replace-with-a-long-random-secret
DB_PATH=./data/chat.sqlite
UPLOAD_DIR=./uploads
APP_RELEASE_DIR=./app_release
MANAGE_HOST=manage.example.com

# Bootstrap the first management admin on a fresh database.
# Leave these blank after the first successful setup if you prefer.
MANAGE_INITIAL_USERNAME=admin
MANAGE_INITIAL_PASSWORD=change-this-password

# Optional local demo data.
SEED_SAMPLE_USERS=false

# Optional web push configuration.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Optional Firebase Cloud Messaging service-account fields.
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# Optional voice-call relay configuration.
CALL_STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
CALL_TURN_URLS=
CALL_TURN_USERNAME=
CALL_TURN_CREDENTIAL=
